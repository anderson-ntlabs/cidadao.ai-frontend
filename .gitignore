# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Generated files
types/generated/
.cache/

# Backup files - Universal patterns
*.backup
*.backup.*
*_backup
*_backup.*
backup_*
backup-*
*.bak
*.bak.*
*_bak
*_bak.*
bak_*
bak-*

# Claude-related files (AI assistant private context)
# Note: CLAUDE.md in root is project documentation and should be committed
# Only block user's private Claude settings
.claude/
*.claude
*.claude.*
claude_*
claude-*
.claude*
# Specific exclusions for private Claude files
~/.claude/
.config/claude/

# Extended backup patterns
*.backup-*
.backup/
backups/
old/
*.old
*.tmp
tmp/

# Project planning files
# Note: Roadmaps and project plans SHOULD be committed for team visibility
# Only blocking work-in-progress private planning files
next-steps.md
*next-steps*
*.planning
*-WIP*.md
*-DRAFT*.md

# Security sensitive files
.secrets/
secrets/
*.secret
*.secret.*
secret_*
secret-*
*.key
*.crt
*.p12
*.pfx
*.jks

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.eslintrc.local.json

# Logs and debugging
logs/
*.log
debug/
*.debug

*storybook.log
storybook-static

# Private technical reports
RELATORIOS-TECNICOS/
*-REPORT-*.md
*-RELATORIO-*.md
RELATORIO-*.md
