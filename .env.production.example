# Production Environment Variables Example
# Copy this file to configure your Vercel production environment
# DO NOT commit actual values - this is just a template

# ===================================
# REQUIRED VARIABLES
# ===================================

# Backend API URL (Production)
# Point to your production backend API (Railway)
NEXT_PUBLIC_API_URL=https://cidadao-api-production.up.railway.app

# Vercel KV (Redis) - Auto-generated when you create KV database
# These will be automatically added by Vercel when you link KV
KV_REST_API_URL=https://your-database.kv.vercel-storage.com
KV_REST_API_TOKEN=your-token-here
KV_REST_API_READ_ONLY_TOKEN=your-readonly-token-here

# ===================================
# OPTIONAL VARIABLES
# ===================================

# Google Analytics Tracking ID
# Get from: https://analytics.google.com
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry Error Tracking
# Get from: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_PROJECT=cidadao-ai-frontend
SENTRY_ORG=your-org-name

# PostHog Analytics & Session Replay
# Get from: https://app.posthog.com
# Used for: Product analytics, session recording, heatmaps, feature flags
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Feature Flags
NEXT_PUBLIC_FEATURE_WEBSOCKET=false
NEXT_PUBLIC_FEATURE_EXPORT=true
NEXT_PUBLIC_FEATURE_NOTIFICATIONS=true

# ===================================
# DEPLOYMENT SETTINGS
# ===================================

# Node Environment (auto-set by Vercel)
NODE_ENV=production

# Vercel System Variables (auto-set, don't configure)
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=your-deployment.vercel.app
# VERCEL_REGION=iad1
# VERCEL_GIT_COMMIT_SHA=abc123

# ===================================
# MONITORING & OBSERVABILITY
# ===================================

# Vercel Analytics (auto-enabled in dashboard)
# No configuration needed

# Custom Metrics Endpoint (if using external service)
# METRICS_ENDPOINT=https://metrics.example.com/api/v1/metrics
# METRICS_API_KEY=your-metrics-api-key

# ===================================
# SECURITY SETTINGS
# ===================================

# Content Security Policy Report URI (optional)
# CSP_REPORT_URI=https://your-domain.report-uri.com/r/d/csp/enforce

# Rate Limiting (using Vercel KV)
# Configured in code, no env vars needed

# ===================================
# PERFORMANCE SETTINGS
# ===================================

# Image Optimization
# Vercel handles this automatically

# Cache Settings
# Configured in vercel.json

# ===================================
# REGIONAL BACKEND URLS (Optional)
# ===================================

# If you have region-specific backend instances
# NEXT_PUBLIC_API_URL_US=https://us.api.cidadao.ai
# NEXT_PUBLIC_API_URL_EU=https://eu.api.cidadao.ai
# NEXT_PUBLIC_API_URL_AP=https://ap.api.cidadao.ai

# ===================================
# THIRD-PARTY INTEGRATIONS
# ===================================

# Supabase (if using for authentication)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===================================
# NOTES
# ===================================

# How to set in Vercel:
# 1. Go to: Settings → Environment Variables
# 2. Add each variable with appropriate scope:
#    - Production: Live site
#    - Preview: PR deployments
#    - Development: Local dev (use .env.local instead)
#
# 3. For sensitive values, use Vercel's encrypted storage
# 4. For KV variables, create KV database first (auto-adds vars)
#
# Security Best Practices:
# - Never commit actual values to git
# - Rotate tokens regularly
# - Use different tokens for each environment
# - Enable 2FA on all service accounts
# - Monitor usage for anomalies
#
# Performance Tips:
# - Use CDN-friendly cache headers
# - Enable compression
# - Minimize environment variable count
# - Use Vercel KV for dynamic config
