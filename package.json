{
  "name": "cidadao-ai-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma Cidadão.AI - Sistema de transparência governamental com inteligência artificial",
  "author": "Anderson Henrique <anderson.ufrj@gmail.com>",
  "license": "MIT",
  "scripts": {
    "dev": "next dev",
    "dev:test": "PORT=3001 next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest --config=config/vitest.config.mjs",
    "test:ui": "vitest --ui --config=config/vitest.config.mjs",
    "test:watch": "vitest --watch --config=config/vitest.config.mjs",
    "test:coverage": "vitest run --coverage --config=config/vitest.config.mjs",
    "test:safe": "NODE_OPTIONS='--max-old-space-size=4096' vitest run --config=config/vitest.config.mjs",
    "test:safe:coverage": "NODE_OPTIONS='--max-old-space-size=4096' vitest run --coverage --config=config/vitest.config.mjs",
    "test:unit": "vitest run --config=config/vitest.config.mjs lib/ hooks/ store/ data/",
    "test:lib": "vitest run --config=config/vitest.config.mjs lib/",
    "test:hooks": "vitest run --config=config/vitest.config.mjs hooks/",
    "test:store": "vitest run --config=config/vitest.config.mjs store/",
    "test:components": "vitest run --config=config/vitest.config.mjs components/",
    "test:single": "vitest run --config=config/vitest.config.mjs",
    "test:playwright": "playwright test --config=config/playwright.config.ts",
    "test:playwright:ui": "playwright test --ui --config=config/playwright.config.ts",
    "test:e2e": "playwright test __tests__/e2e --config=config/playwright.config.ts",
    "test:e2e:ui": "playwright test __tests__/e2e --ui --config=config/playwright.config.ts",
    "test:mobile": "playwright test --config=config/playwright.mobile.config.ts",
    "test:mobile:ui": "playwright test --config=config/playwright.mobile.config.ts --ui",
    "test:mobile:headed": "playwright test --config=config/playwright.mobile.config.ts --headed",
    "test:mobile:debug": "playwright test --config=config/playwright.mobile.config.ts --debug",
    "test:design-system": "playwright test tests/e2e/design-system/",
    "test:install": "playwright install",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "generate:component": "node scripts/generate-component.js",
    "generate:types": "node scripts/generate-api-types.js",
    "analyze": "ANALYZE=true npm run build",
    "analyze:server": "ANALYZE=true BUNDLE_ANALYZE=server npm run build",
    "analyze:browser": "ANALYZE=true BUNDLE_ANALYZE=browser npm run build",
    "prepare": "husky",
    "postinstall": "cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/pdf.worker.min.mjs 2>/dev/null || true"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.19",
