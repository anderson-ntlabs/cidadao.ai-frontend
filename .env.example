# Backend API URL (HTTPS only - HTTP blocked by Service Worker)
# Default: https://cidadao-api-production.up.railway.app
NEXT_PUBLIC_API_URL=

# Google Analytics ID (optional)
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Environment
# Options: development, production
NODE_ENV=development

# PWA Settings (optional)
# Set to true to disable PWA in development
DISABLE_PWA=true

# Accessibility Features
# VLibras (Brazilian Sign Language - LIBRAS) Integration
# Set to true to enable VLibras widget on Portuguese pages
# Default: true (always enabled for accessibility)
NEXT_PUBLIC_ENABLE_VLIBRAS=true

# Analytics & Research
# PostHog Analytics for usability research
# Get your API key at: https://app.posthog.com
# Leave empty to disable analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com